#logik systemu
globalny_tryb = False # False = Tryb Praca, True = Tryb Dom

def aktualizuj_stan_domu():
    # ustawiamy wszystko tak, jak mówi aktualny Tryb 
    for s in swiatla:
        s["stan"] = globalny_tryb
    for system in inne_systemy.values():
        system["stan"] = globalny_tryb

    # 2. priorytet Czujniki nadpisują stan dla swoich pomieszczeń
    for cz in czujniki:
        if cz["stan"] == True: # Jeśli wykryto ruch
            for idx in cz["swiatla_idx"]:
                swiatla[idx]["stan"] = True # Wymuszamy WŁĄCZENIE tego światła

    # Rysowanie zaktualizowanych kolorów na planie (Canvas)
    for s in swiatla:
        if s["stan"]:
            canvas.itemconfig(s["canvas"], fill=s["kolor"])
        else:
            canvas.itemconfig(s["canvas"], fill="white")
            
        for system in inne_systemy.values():
            system["stan"] = False
            canvas.itemconfig(system["id"], fill="white")
            
            if not globalny_tryb:
                canvas.itemconfig(system["id_text"],text=system["text"])
                
            
            else:
                canvas.itemconfig(system["id_text"],text=system["alt_text"])
                canvas.itemconfig(system["id"], fill=system["kolor"])
                
    # Aktualizacja koloru czajnika zależy TYLKO od globalnego trybu
    if globalny_tryb:
        canvas.itemconfig(czajnik_id, fill="red")
    else:
        canvas.itemconfig(czajnik_id, fill="white")


def tryb_praca():
    global globalny_tryb
    globalny_tryb = False
    aktualizuj_stan_domu()

def tryb_dom():
    global globalny_tryb
    globalny_tryb = True
    aktualizuj_stan_domu()

def przelacz_czujnik(i):
    # Zmienia stan konkretnego czujnika
    czujniki[i]["stan"] = not czujniki[i]["stan"]
    
    if czujniki[i]["stan"]:
        # Jeśli wykryto ruch - kolor czerwony
        canvas.itemconfig(czujniki[i]["canvas"], fill="red")
        czujniki[i]["button"].config(text=f"{czujniki[i]['nazwa']}: WYKRYTO", bg="#ffb3b3")
    else:
        # Jeśli brak ruchu - kolor zielony
        canvas.itemconfig(czujniki[i]["canvas"], fill="green")
        czujniki[i]["button"].config(text=f"{czujniki[i]['nazwa']}: BRAK", bg="#b3ffb3")
    
    # Odpalamy aktualizację - czujnik nadpisze teraz stan GUI
    aktualizuj_stan_domu()


